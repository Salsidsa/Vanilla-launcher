<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.irislauncher.ui.ModSearchController"
      stylesheets="@launcher.css"
      style="-fx-background-color: #111827;"
      spacing="0">

    <!-- Search bar -->
    <HBox spacing="8" style="-fx-padding: 16; -fx-background-color: #111827;">
        <TextField fx:id="searchField"
                   promptText="Search mods on Modrinth..."
                   styleClass="search-field"
                   HBox.hgrow="ALWAYS"/>
        <Button fx:id="searchButton"
                text="Search"
                onAction="#onSearch"
                styleClass="play-button"
                style="-fx-font-size: 13px; -fx-padding: 8 18; -fx-background-radius: 4;"/>
    </HBox>

    <!-- Status line -->
    <Label fx:id="statusLabel" text="Enter a mod name to search"
           style="-fx-text-fill: rgba(255,255,255,0.35); -fx-font-size: 10px; -fx-padding: 0 16 8 16;"/>

    <!-- Results -->
    <ListView fx:id="resultsList"
              VBox.vgrow="ALWAYS"
              styleClass="mod-list"/>

</VBox>
